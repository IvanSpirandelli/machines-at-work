# Workspace config. Shell-sourceable. Validated by scripts/preflight.sh.
PROJECT_NAME=myproject
DEFAULT_BRANCH=main

# How finished tasks land. local = squash-merge to DEFAULT_BRANCH (solo repos).
# pr = push the task branch and open a GitHub PR (shared repos; needs `gh`
# authenticated and an origin remote — tasks then complete via task.sh sync
# once a human merges the PR).
DONE=local

# Repo names (space-separated). For each name X: REPO_X = path relative to
# this file (repos are siblings of machines-at-work/, hence ../), VERIFY_X = one
# command that builds, lints, and tests.
REPOS="app"
REPO_app=../app
VERIFY_app="echo 'TODO: set verify command' && false"

# Optional: notify.sh → Telegram. Bot token + chat id are shared across projects
# (keep them in ~/.agent-orchestrator/telegram.env, or set here); the topic id is
# per-project — the forum topic this project's escalations report into.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_TOPIC_ID=

# Optional: /plan creates one Linear issue per approved plan run and embeds its
# key in every feature slug, so each PR auto-links to the issue. Needs DONE=pr
# (Linear links via the PR branch) and LINEAR_API_KEY (shared, in
# ~/.agent-orchestrator/linear.env). Unset ⇒ off.
# LINEAR_TEAM_KEY=ENG
